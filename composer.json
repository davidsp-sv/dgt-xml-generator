{
  "name": "dazza-dev/dgt-xml-generator",
  "description": "Paquete para la generación de archivos XML validos para la facturación electrónica 4.4 Costa Rica.",
  "keywords": [
    "dgt",
    "factura electrónica"
  ],
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.0",
    "twig/twig": "^3.19"
  },
  "config": {
    "preferred-install": "dist",
    "sort-packages": true,
    "optimize-autoloader": true
  },
  "minimum-stability": "stable",
  "authors": [
    {
      "name": "Andres Daza",
      "email": "adaza90@outlook.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "DazzaDev\\DgtXmlGenerator\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "DazzaDev\\DgtXmlGenerator\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "phpstan/phpstan": "^2.1"
  },
  "scripts": {
    "test": "phpunit",
    "test-coverage": "phpunit --coverage-html coverage",
    "analyse": "phpstan analyse",
    "analyse-level": "phpstan analyse --level",
    "test-static": "phpstan analyse --no-progress"
  }
}
