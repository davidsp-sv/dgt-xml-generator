{% for payment in payments %}
<MedioPago>
  <TipoMedioPago>{{ payment.payment_method.code }}</TipoMedioPago>
  {% if payment.other_payment_method %}
  <MedioPagoOtros>{{ payment.other_payment_method }}</MedioPagoOtros>
  {% endif %}
  <TotalMedioPago>{{ (payment.amount|default(0))|number_format(2, '.', '') }}</TotalMedioPago>
</MedioPago>
{% endfor %}
